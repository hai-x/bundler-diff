{
  "name": "side-effects-values",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:all": "pnpm run build:turbopack && pnpm run build:rspack && pnpm run build:webpack && pnpm run build:esbuild && pnpm run build:rolldown",
    "build:webpack": "webpack --config ../../../configs/webpack.base.cjs",
    "build:turbopack": "cargo run --manifest-path ../../../crates/turbopack-cli/Cargo.toml -- build --dir . --root . --target node --no-minify --no-sourcemap src/entry.js",
    "build:rspack": "rspack build --config ../../../configs/rspack.base.cjs",
    "build:esbuild": "node ../../../configs/esbuild.base.mjs",
    "build:rolldown": "rolldown -c ../../../configs/rolldown.base.mjs"
  },
  "devDependencies": {
    "loader-runner": "^4.3.0"
  }
}
