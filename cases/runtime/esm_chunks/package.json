{
  "name": "esm-chunks-case",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:all": "pnpm run build:turbopack && pnpm run build:rspack",
    "build:turbopack": "cargo run --manifest-path ../../../crates/turbopack-cli/Cargo.toml -- build --dir . --root . --target node --no-minify --no-sourcemap src/entry.js",
    "build:rspack": "rspack build --config rspack.config.cjs"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.6",
    "@rspack/core": "^2.0.6"
  },
  "packageManager": "pnpm@10.33.0"
}
