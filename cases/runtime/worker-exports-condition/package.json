{
  "name": "worker-exports-condition-case",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:all": "pnpm run build:turbopack && pnpm run build:rspack && pnpm run build:webpack && pnpm run build:esbuild && pnpm run build:rolldown",
    "build:turbopack": "cargo run --manifest-path ../../../crates/turbopack-cli/Cargo.toml -- build --dir . --root ../../.. --target browser --no-minify --no-sourcemap ./cases/runtime/worker-exports-condition/src/entry.js",
    "build:rspack": "rspack build --config rspack.config.cjs",
    "build:webpack": "webpack --config webpack.config.cjs",
    "build:webpack:layers": "webpack --config webpack.layers.config.cjs",
    "build:esbuild": "node esbuild.config.mjs",
    "build:rolldown": "rolldown -c rolldown.config.mjs"
  },
  "dependencies": {
    "decode-named-character-reference": "file:./vendor/decode-named-character-reference"
  }
}
